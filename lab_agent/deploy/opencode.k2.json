{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "k2think": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "K2 Think API through Bonsai policy gateway",
      "options": {
        "baseURL": "http://127.0.0.1:18080/v1",
        "apiKey": "local-policy-gateway"
      },
      "models": {
        "MBZUAI-IFM/K2-Think-v2": {
          "name": "K2 Think V2 high reasoning",
          "limit": {
            "context": 131072,
            "output": 131072
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama on PVE-Chert (rollback)",
      "options": {
        "baseURL": "http://100.96.0.4:11434/v1"
      },
      "models": {
        "qwen3.6:27b-96k": {
          "name": "Qwen3.6 27B 96K",
          "limit": {
            "context": 98304,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "k2think/MBZUAI-IFM/K2-Think-v2",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "*dwarfort*": "deny",
      "*dfhack-run*": "deny",
      "*/bonsai-df-probe *": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 24000
  }
}
